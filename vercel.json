{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python -m prisma generate",
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "env": {
    "PRISMA_QUERY_ENGINE_BINARY": "rhel-openssl-1.0.x",
    "PRISMA_CLI_BINARY_TARGETS": "rhel-openssl-1.0.x"
  }
}

