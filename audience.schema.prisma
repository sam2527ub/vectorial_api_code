generator audience_client {
  provider             = "prisma-client-py"
  output               = "./audience_prisma_client"
  binaryTargets        = ["native", "rhel-openssl-1.0.x"]
  interface            = "asyncio"
  recursive_type_depth = "5"
}

datasource audience_db {
  provider = "postgresql"
  url      = env("AUDIENCE_DATABASE_URL")
}

model AudienceRoom {
  id               String            @id @default(uuid())
  name             String
  descriptionS3Url String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userId           String?
  profiles         AudienceProfile[]

  @@index([name])
  @@index([userId])
}

model AudienceProfile {
  id                      String       @id @default(uuid())
  audienceRoomId          String
  profileName             String
  linkedinUrl             String
  profileDescriptionS3Url String?
  postsS3Url              String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  audienceRoom            AudienceRoom @relation(fields: [audienceRoomId], references: [id], onDelete: Cascade)

  @@index([audienceRoomId])
}

model PostClassifier {
  id          String   @id @default(uuid())
  userId      String?
  name        String
  description String?
  prompt      String
  labels      String[]
  examples    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model ChatAssets {
  chatId    String   @id
  userId    String?
  productId String?
  asset     Json
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([userId])
}

model CustomClone {
  id          String   @id
  userId      String
  userEmail   String
  cloneName   String
  description String?
  category    String?
  metadata    Json
  keywords    String[]
  profiles    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([category])
  @@index([userEmail])
  @@index([userId])
}

model PreMadePrompt {
  id          String   @id
  trigger     String   @unique
  name        String
  description String
  prompt      String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([active])
}

model ScrapeJob {
  id           String   @id
  status       String   @default("PENDING")
  linkedinUrls Json
  maxPosts     Int
  apifyRunId   String?
  result       Json?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([createdAt])
  @@index([status])
}

model SearchQuery {
  id          String   @id
  filters     Json
  sqlQuery    String
  resultCount Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model StoryActions {
  storyId   String @id
  actions   Json
  actionsUI Json
}

model StoryComment {
  id        String   @id
  storyId   String
  userId    String
  userEmail String?
  userName  String?
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([storyId])
}

model VapiCallConfig {
  id        String   @id
  sessionId String   @unique
  config    Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@index([sessionId])
}

model VapiToolResult {
  id        String   @id
  sessionId String   @unique
  query     String
  raw       String
  sanitized String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
}

