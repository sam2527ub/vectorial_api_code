// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
  recursive_type_depth = 5
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
  output = "./prisma_client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScrapeJob {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  linkedinUrls Json   // Array of LinkedIn URLs
  maxPosts    Int
  apifyRunId  String?  // Apify run ID
  result      Json?    // Scraped results
  error       String?  // Error message if failed
  audienceRoomId String? // Optional audience room to auto-map posts on completion
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([audienceRoomId])
}

model SearchQuery {
  id          String   @id @default(uuid())
  filters     Json     // Search filters (titles, skills, locations, etc.)
  sqlQuery    String   // Generated SQL query
  resultCount Int      // Number of profiles found
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Async Profile Summaries Job tracking
model SummariesJob {
  id                 String   @id @default(uuid())
  status             String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  audienceRoomId     String
  totalProfiles      Int      @default(0)
  processedProfiles  Int      @default(0)
  successCount       Int      @default(0)
  skippedCount       Int      @default(0)
  errorCount         Int      @default(0)
  currentChunk       Int      @default(0)
  totalChunks        Int      @default(0)
  error              String?  // Error message if failed
  taskToken          String?  // Step Functions callback token
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([audienceRoomId])
  @@index([createdAt])
}

// Async Classifier Job tracking
model ClassifierJob {
  id                   String   @id @default(uuid())
  status               String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  classifierId         String
  audienceRoomId       String
  totalProfiles        Int      @default(0)
  processedProfiles    Int      @default(0)
  totalPostsClassified Int      @default(0)
  error                String?  // Error message if failed
  taskToken            String?  // Step Functions callback token
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status])
  @@index([audienceRoomId])
  @@index([classifierId])
  @@index([createdAt])
}

// Async Parallel Scraping Job tracking (for batched parallel runs)
model ParallelScrapeJob {
  id             String   @id @default(uuid())
  status         String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  audienceRoomId String?
  totalBatches   Int      @default(0)
  completedBatches Int    @default(0)
  totalUrls      Int      @default(0)
  processedUrls  Int      @default(0)
  batchRunIds    Json?    // Array of Apify run IDs for each batch
  error          String?  // Error message if failed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([audienceRoomId])
  @@index([createdAt])
}
