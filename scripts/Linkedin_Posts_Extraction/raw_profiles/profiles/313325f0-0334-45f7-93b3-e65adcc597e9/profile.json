tType": null}, {"companyId": null, "companyUrn": null, "companyLink1": null, "companyName": "New York University High performance Computing", "companySize": null, "companyWebsite": null, "companyIndustry": null, "logo": null, "title": "Student System Administrator", "jobDescription": "- Developed Python scripts to automate the process of summarizing data of about 3000 NYU\u2019s HPC users data.\n- Taught classes to new and prospective users of NYU HPC clusters on Linux and Bash shell scripting.\n- Conducted stress tests to simulate workload of  approximately 200 users for NYU\u2019s in house Hadoop cluster.\n- Developed PHP scripts to create custom modules of the Chain-Builder system for the Monterrey project website.\n- In collaboration with Google, tested the Google Cloud Slurm cluster deployment system for HPC workloads.\n- Acted as Scrum master for the Monterrey project and was responsible for mitigating roadblocks of the team.", "jobStartedOn": "8-2017", "jobEndedOn": "6-2018", "jobLocation": "Greater New York City Area", "jobStillWorking": false, "jobLocationCountry": null, "employmentType": null}, {"companyId": "164340", "companyUrn": "urn:li:fsd_company:164340", "companyLink1": "https://www.linkedin.com/school/indian-institute-of-science/", "companyName": "Indian Institute of Science (IISc)", "companySize": "1001-5000", "companyWebsite": "http://www.iisc.ac.in/", "companyIndustry": "Research", "logo": "https://media.licdn.com/dms/image/v2/C560BAQHlKBtJ82x7_Q/company-logo_400_400/company-logo_400_400/0/1630652697970/indian_institute_of_science_logo?e=1775692800&v=beta&t=Ae5Pep5OI7cVJ5xuW-LgkavupCJUOZLL3yjpAMsSQM4", "title": "Project assitant", "jobDescription": "The project involved developing a regional 10km grid for the Modular Ocean Model (MOM).\n\n- Discovered and reported a bug in the implementation of the conservative interpolation function of MOM.\n- Successfully developed the grid and integrated into MOM.", "jobStartedOn": "7-2016", "jobEndedOn": "11-2016", "jobLocation": "Bengaluru Area, India", "jobStillWorking": false, "jobLocationCountry": "IN", "employmentType": null}, {"companyId": "164340", "companyUrn": "urn:li:fsd_company:164340", "companyLink1": "https://www.linkedin.com/school/indian-institute-of-science/", "companyName": "Indian Institute of Science (IISc)", "companySize": "1001-5000", "companyWebsite": "http://www.iisc.ac.in/", "companyIndustry": "Research", "logo": "https://media.licdn.com/dms/image/v2/C560BAQHlKBtJ82x7_Q/company-logo_400_400/company-logo_400_400/0/1630652697970/indian_institute_of_science_logo?e=1775692800&v=beta&t=Ae5Pep5OI7cVJ5xuW-LgkavupCJUOZLL3yjpAMsSQM4", "title": "Project Assistant", "jobDescription": "I worked on a collaborative project undertaken by the Department of Computational Data Sciences (erstwhile SERC) and Centre of atmospheric and oceanic sciences (CAOS) on developing optimization strategies for the Ocean module of Community Earth System Model (CESM)  using the Intel Xeon Phi architecture. \n\nDiscovered inefficient implementation of the WHERE loop constructs by the Intel Fortran Compilers.\n\u2022 Analyzed over 100,000 lines of Fortran code and optimized it to achieve 23% reduction in execution time.\n\u2022 Analyzed horizontal diffusion calculation for minimizing data transfer and achieved an 8x reduction.", "jobStartedOn": "10-2014", "jobEndedOn": "7-2016", "jobLocation": "Bengaluru Area, India", "jobStillWorking": false, "jobLocationCountry": "IN", "employmentType": null}], "updates": [], "skills": [{"title": "Apache Kafka"}, {"title": "Elastic Stack (ELK)"}, {"title": "Windows Presentation Foundation (WPF)"}, {"title": "LLVM"}, {"title": "Performance Management"}, {"title": "Kubernetes"}, {"title": "Amazon EC2"}, {"title": "Amazon S3"}, {"title": "Amazon EKS"}, {"title": "AWS Elastic Beanstalk"}, {"title": "Amazon SQS"}, {"title": "Amazon Simple Notification Service (SNS)"}, {"title": "Distributed Systems"}, {"title": "Cloud Computing"}, {"title": "GNU/Linux"}, {"title": "Unix"}, {"title": "Docker"}, {"title": "Amazon Web Services (AWS)"}, {"title": "Microsoft Azure"}, {"title": "Large Language Models (LLM)"}], "creatorWebsite": [], "profilePicAllDimensions": [], "educations": [{"companyId": "40084", "companyUrn": "urn:li:fsd_company:40084", "companyLink1": "https://www.linkedin.com/school/m.s.-ramaiah-institute-of-technology/", "logo": "https://media.licdn.com/dms/image/v2/C4D0BAQGgBgaivzxtSQ/company-logo_200_200/company-logo_200_200/0/1631351693651?e=1775692800&v=beta&t=uaKnnZSJ8ML8EBv5fu_Yj8OfIMrBUlTiclzLGCmWsLI", "title": "Ramaiah Institute Of Technology", "subtitle": "Bachelor's Degree, Computer Science", "description": "Undergraduate Student at MSRIT in Computer science.", "grade": "8.64", "period": {"startedOn": {"year": 0, "month": 0}, "endedOn": {"year": 0, "month": 0}}}, {"companyId": "18993", "companyUrn": "urn:li:fsd_company:18993", "companyLink1": "https://www.linkedin.com/school/new-york-university/", "logo": "https://media.licdn.com/dms/image/v2/C4D0BAQF6TmzLkch0dQ/company-logo_200_200/company-logo_200_200/0/1630556159190/new_york_university_logo?e=1775692800&v=beta&t=lcSs8C-l3cZlwD5tk4EmYr-SJ0LHlmjY82wjUR2ZcRI", "title": "New York University", "subtitle": "Master of Science - MS, Computer Science", "description": null, "grade": null, "period": {"startedOn": {"year": 0, "month": 0}, "endedOn": {"year": 0, "month": 0}}}], "licenseAndCertificates": [{"name": "Machine Learning - Regression", "startedOn": {"year": 2016, "month": 2, "day": null}, "authority": "Coursera", "company_id": "", "url": "https://linkedin.com/company/2453129"}, {"name": "Machine Learning", "startedOn": {"year": 2017, "month": 9, "day": null}, "authority": "Coursera", "company_id": "", "url": "https://linkedin.com/company/2453129"}], "honorsAndAwards": [], "languages": [{"name": "English", "proficiency": ""}, {"name": "Hindi", "proficiency": ""}], "volunteerAndAwards": [], "verifications": [], "promos": [], "highlights": [], "projects": [], "publications": [{"title": "High performance Horizontal Diffusion Calculations in Ocean Models on Intel Xeon Phi Co-Processor Systems.", "source": "International Conference on High Performance Computing (HiPC). December 2016, Hyderabad, India", "summary": "Accelerators and co-processors are widely prevalent and have been used to provide high performance for many scientific applications. Intel\u00ae Xeon Phi\u2122 coprocessors have been gaining ground to provide speedups for advanced scientific applications. However, the use and demonstration of these coprocessors for climate modeling are limited. In this work, we have developed a comprehensive set of novel techniques for efficient use of Intel Xeon Phi coprocessors for ocean modeling. In particular, we focus on one of the most time consuming routines, namely, horizontal diffusion in tracers (hdifft). Our techniques include explicit and implicit fusion for data locality and vectorization, choice of coarse-grained over fine-grained parallelism, offloading hdifft function for asynchronous and simultaneous executions on CPU and accelerator cores, and effective data management to minimize CPU-accelerator data transfer overheads. Our comprehensive set of techniques has resulted in about 17-23% improvement in simulation throughput of the entire ocean model code. Our optimization strategies exhibit good scaling with the use of more Intel Xeon Phi processors. Among our optimization techniques, the use of our novel look-ahead asynchronous execution strategy on Intel Xeon Phis resulted in maximum benefit yielding about 36% improvement in performance.", "url": "http://ieeexplore.ieee.org/document/7839685/", "publishing_date": "Dec 19, 2016"}], "patents": [], "courses": [], "testScores": [], "organizations": [], "volunteerCauses": [], "interests": [], "recommendationsReceived": [], "recommendations": [], "peopleAlsoViewed": [{"last_name": "Kamanalli Shivanandappa", "first_name": "Sahana", "headline": "Hardware Applications