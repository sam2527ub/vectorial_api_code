 environment.", "highlights": ["Senior Software Engineer (Microsoft)", "Enterprise / Mature Tech (Microsoft)", "Women in Tech Advocate", "Cross-disciplinary: Pianist + Engineer", "Thoughtful Storyteller & Thought Leadership", "Collaborative Innovator (Hackathon Winner / Team Contributor)"], "keywords": ["Microsoft", "software engineering", "Women of Microsoft", "WomenInTech", "pianist", "Van Cliburn", "burnout prevention", "work-life balance", "time management", "resilience", "Microsoft Hackathon", "public speaking / media feature", "authentic storytelling", "creative + technical", "community engagement"], "postCount": 9}