nt setting. We show our technique for achieving comparable protocol behavior via experiments and simulations in multiple indoor and outdoor propagation environments. The link usage spectrum is protocol specific; we illustrate for a family of protocols how the link usage spectrum is calculated analytically, from the protocol metric for choosing forwarding links in the network, and how power scaling can be used to match the link usage spectrum across networks.", "url": "http://dl.acm.org/citation.cfm?id=2142407", "publishing_date": "Jun 1, 2012"}], "patents": [], "courses": [], "testScores": [], "organizations": [], "volunteerCauses": [], "interests": [], "recommendationsReceived": [], "recommendations": [], "peopleAlsoViewed": [{"last_name": "Wang", "first_name": "Xianhao", "headline": "Software Engineer", "entity_urn": "urn:li:fsd_profile:ACoAAC1drKgBakjUReSE9mxN-Xw8r7qx1Xe3S68", "public_identifier": "xianhao-wang", "premium": false, "profile_picture": "https://media.licdn.com/dms/image/v2/C5603AQHUaJKDw4zEWg/profile-displayphoto-shrink_800_800/profile-displayphoto-shrink_800_800/0/1657563435363?e=1775692800&v=beta&t=JiEGcvTs2hXR7O3JL2pUfvzXTrKNeL8WToZ7WvOKzmQ", "url": "https://linkedin.com/in/ACoAAC1drKgBakjUReSE9mxN-Xw8r7qx1Xe3S68", "follower_count": 343}, {"last_name": "Roberts", "first_name": "Kyle", "headline": "Simulation Project Engineer at Cadence", "entity_urn": "urn:li:fsd_profile:ACoAAB6YYZoBz7Qwft9m1NB8wnmFTOi0ExD45Bw", "public_identifier": "kyle-roberts-38aaa2123", "premium": false, "profile_picture": "https://media.licdn.com/dms/image/v2/C4E03AQFG0wknrHcmmw/profile-displayphoto-shrink_800_800/profile-displayphoto-shrink_800_800/0/1571332743199?e=1775692800&v=beta&t=8sFbgcFQK467UZIDmSFe7SAM4SrYD51aCo8EZtEwy4o", "url": "https://linkedin.com/in/ACoAAB6YYZoBz7Qwft9m1NB8wnmFTOi0ExD45Bw", "follower_count": 228}, {"last_name": "Wu", "first_name": "Yimiao", "headline": "Software Engineer", "entity_urn": "urn:li:fsd_profile:ACoAAB5UcmcBF5f345mmfHXozRtPcdu16O4o5